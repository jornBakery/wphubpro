# Shared Appwrite function runtime variables
APPWRITE_ENDPOINT=https://appwrite.example.com/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key

# Alternative aliases used by some functions/runtimes
APPWRITE_FUNCTION_ENDPOINT=https://appwrite.example.com/v1
APPWRITE_FUNCTION_PROJECT_ID=your_appwrite_project_id
APPWRITE_FUNCTION_API_KEY=your_appwrite_api_key
APPWRITE_KEY=your_appwrite_api_key

# Shared IDs
APPWRITE_DATABASE_ID=platform_db
DATABASE_ID=platform_db
ACCOUNTS_COLLECTION_ID=accounts
SUBSCRIPTIONS_COLLECTION_ID=subscriptions
LIBRARY_COLLECTION_ID=library

# Security / encryption
ENCRYPTION_KEY=change_me_to_a_long_random_secret

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional S3 (used by zip-parser)
S3_BUCKET=your_bucket_name
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
